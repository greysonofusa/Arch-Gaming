[
  {
    "layer": "top",
    "position": "top",
    "height": 52,
    "spacing": 0,
    "exclusive": true,
    "margin-right": -15,
    "modules-left": ["custom/launcher","custom/file","custom/edit","custom/view"],
    "modules-center": ["custom/browser","custom/steam","custom/onlyoffice","custom/thunar","wlr/taskbar"],
    "modules-right": ["custom/volume","cpu","memory","battery","clock","custom/power"],

    "custom/launcher": {"format": "", "on-click": "wofi --show drun", "tooltip": false},
    "custom/file":     {"exec": "echo File",  "interval": 3600, "return-type": "plain", "on-click": "bash ~/.config/mango/scripts/file-menu.sh",  "tooltip": false},
    "custom/edit":     {"exec": "echo Edit",  "interval": 3600, "return-type": "plain", "on-click": "bash ~/.config/mango/scripts/edit-menu.sh",  "tooltip": false},
    "custom/view":     {"exec": "echo View",  "interval": 3600, "return-type": "plain", "on-click": "bash ~/.config/mango/scripts/view-menu.sh",  "tooltip": false},

    "custom/browser":    {"format": "", "on-click": "cromite",                  "on-click-right": "bash ~/.config/mango/scripts/app-right-click.sh cromite",   "tooltip": true, "tooltip-format": "Cromite"},
    "custom/steam":      {"format": "", "on-click": "steam",                    "on-click-right": "bash ~/.config/mango/scripts/app-right-click.sh steam",     "tooltip": true, "tooltip-format": "Steam"},
    "custom/onlyoffice": {"format": "", "on-click": "onlyoffice-desktopeditors","on-click-right": "bash ~/.config/mango/scripts/app-right-click.sh onlyoffice","tooltip": true, "tooltip-format": "OnlyOffice"},
    "custom/thunar":     {"format": "", "on-click": "thunar",                   "on-click-right": "bash ~/.config/mango/scripts/app-right-click.sh thunar",    "tooltip": true, "tooltip-format": "Files"},

    "wlr/taskbar": {
      "format": "{icon}", "icon-size": 28, "icon-theme": "Papirus",
      "spacing": 0, "on-click": "activate", "on-click-middle": "close",
      "tooltip-format": "{title}", "ignore-list": []
    },

    "custom/volume": {
      "exec": "bash ~/.config/mango/scripts/volume.sh get",
      "return-type": "json", "interval": 2, "signal": 1,
      "on-click": "bash ~/.config/mango/scripts/volume.sh mute",
      "on-scroll-up": "bash ~/.config/mango/scripts/volume.sh up",
      "on-scroll-down": "bash ~/.config/mango/scripts/volume.sh down",
      "on-click-right": "pavucontrol", "tooltip": true
    },

    "cpu":    {"interval": 3,  "format": " {usage}%",          "on-click": "kitty -e btop", "tooltip-format": "CPU: {usage}%"},
    "memory": {"interval": 10, "format": " {used:0.1f}G",      "on-click": "kitty -e btop", "tooltip-format": "{used:0.2f}G / {total:0.2f}G"},

    "battery": {
      "interval": 30,
      "states": {"warning": 30, "critical": 15},
      "format": "{icon} {capacity}%",
      "format-charging": " {capacity}%",
      "format-plugged": " {capacity}%",
      "format-full": " Full",
      "format-icons": ["", "", "", "", ""],
      "tooltip-format": "Battery: {capacity}%"
    },

    "clock": {
      "interval": 1,
      "format": "%a %b %d  %H:%M",
      "tooltip-format": "{:%B %Y}"
    },

    "custom/power": {
      "format": "⏻",
      "on-click": "bash $HOME/.config/mango/scripts/power-menu.sh",
      "tooltip": false
    }
  }
]
